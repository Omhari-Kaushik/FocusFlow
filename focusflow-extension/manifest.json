{
  "manifest_version": 3,
  "name": "FocusFlow Distraction Shield",
  "version": "3.1",
  "description": "Blocks distracting websites globally using declarativeNetRequest.",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://localhost:80/*",
        "http://127.0.0.1:80/*",
        "http://localhost:5500/*",
        "http://127.0.0.1:5500/*",
        "http://localhost:5501/*",
        "http://127.0.0.1:5501/*",
        "http://localhost:5502/*",
