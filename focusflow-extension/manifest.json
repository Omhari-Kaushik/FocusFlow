        "http://localhost:8082/*",
        "http://127.0.0.1:8082/*",
        "http://localhost:8083/*",
        "http://127.0.0.1:8083/*",
        "http://localhost:8084/*",
        "http://127.0.0.1:8084/*",
        "http://localhost:8085/*",
        "http://127.0.0.1:8085/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://localhost:3001/*",
        "http://127.0.0.1:3001/*",
        "http://localhost:3002/*",
        "http://127.0.0.1:3002/*",
        "http://localhost:3003/*",
        "http://127.0.0.1:3003/*",
        "http://localhost:3004/*",
